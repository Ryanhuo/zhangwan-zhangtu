{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/data/**",
              "components/feedback/**",
              "components/forms/**",
              "components/navigation/**",
              "ui_kits/zhangwan-console/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:PingFang SC|DIN-Medium|Noto Sans SC))/i]",
        "message": "Font not provided by the design system. Available: PingFang SC, DIN-Medium, Noto Sans SC."
      },
      {
        "selector": "JSXOpeningElement[name.name='BreadcrumbItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|key|ref|className|style|children)$/]",
        "message": "<BreadcrumbItem> doesn't accept that prop. Declared props: label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|loading|disabled|icon|onClick|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, loading, disabled, icon, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|default|text|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'default' | 'text' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:small|medium|large)$/]",
        "message": "<Button> size must be one of 'small' | 'medium' | 'large'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|checked|disabled|onChange|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: label, checked, disabled, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='ColumnChartDatum'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|key|ref|className|style|children)$/]",
        "message": "<ColumnChartDatum> doesn't accept that prop. Declared props: label, value."
      },
      {
        "selector": "JSXOpeningElement[name.name='ColumnSettingsChild'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|checked|key|ref|className|style|children)$/]",
        "message": "<ColumnSettingsChild> doesn't accept that prop. Declared props: label, checked."
      },
      {
        "selector": "JSXOpeningElement[name.name='TableColumn'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|prop|width|align|fixed|sortable|render|key|ref|className|style|children)$/]",
        "message": "<TableColumn> doesn't accept that prop. Declared props: label, prop, width, align, fixed, sortable, render."
      },
      {
        "selector": "JSXOpeningElement[name.name='TableColumn'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center|right)$/]",
        "message": "<TableColumn> align must be one of 'left' | 'center' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TableColumn'] > JSXAttribute[name.name='fixed'] > Literal[value!=/^(?:left)$/]",
        "message": "<TableColumn> fixed must be one of 'left'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DatePreset'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|range|key|ref|className|style|children)$/]",
        "message": "<DatePreset> doesn't accept that prop. Declared props: label, range."
      },
      {
        "selector": "JSXOpeningElement[name.name='Dialog'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|title|width|children|confirmLoading|onCancel|onConfirm|key|ref|className|style|children)$/]",
        "message": "<Dialog> doesn't accept that prop. Declared props: open, title, width, children, confirmLoading, onCancel, onConfirm."
      },
      {
        "selector": "JSXOpeningElement[name.name='DownloadTask'] > JSXAttribute > JSXIdentifier[name!=/^(?:taskCode|status|taskName|queryText|createTime|completeTime|path|key|ref|className|style|children)$/]",
        "message": "<DownloadTask> doesn't accept that prop. Declared props: taskCode, status, taskName, queryText, createTime, completeTime, path."
      },
      {
        "selector": "JSXOpeningElement[name.name='Drawer'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|title|width|children|footer|confirmLoading|onCancel|onConfirm|key|ref|className|style|children)$/]",
